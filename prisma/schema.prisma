// This is your Prisma schema file, simplified for the new requirements

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  CAMPUS_REPRESENTATIVE
  PARENT
  TEACHER
  VOLUNTEER
}

enum PermissionType {
  CREATE_CAMPUS
  READ_CAMPUS
  UPDATE_CAMPUS
  DELETE_CAMPUS
  MANAGE_ADMINS
  MANAGE_CAMPUS_REPS
  VIEW_ANALYTICS
}

enum ProfileFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  CHECKBOX
  SELECT
  MULTI_SELECT
  RADIO
  FILE
  PHONE
}

enum FormFieldAudience {
  CAMPER
  TEACHER
  VOLUNTEER
}

enum FormFieldSource {
  SYSTEM
  CUSTOM
}

enum RegistrationStatus {
  DRAFT
  SUBMITTED
  PENDING
  REQUIRES_ACTION
  APPROVED
  REJECTED
  WAITLISTED
  CANCELLED
  CHECKED_IN
  COMPLETED
  ARCHIVED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  passwordSet      Boolean        @default(false)
  emailVerified    DateTime?
  emailVerifyToken String?
  photoUrl         String?
  role             UserRole
  firstName        String?
  lastName         String?
  phone            String?
  active           Boolean        @default(true)
  organization     Organization?  @relation(fields: [organizationId], references: [id])
  organizationId   String?
  homeCampus       Campus?        @relation("UserCampus", fields: [homeCampusId], references: [id])
  homeCampusId     String?
  managedCampuses  Campus[]       @relation("CampusReps")
  permissions      Permission[]
  campers          Camper[] // User can have multiple camper profiles
  staffProfiles    StaffProfile[]
  reportsFromStaff StaffProfile[] @relation("StaffReportsToUser")
  scanEvents       ScanEvent[]
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([deletedAt])
}

model Organization {
  id           String      @id @default(cuid())
  name         String      @unique
  slug         String?
  users        User[]
  campuses     Campus[]
  formFields   FormField[] // Organization defines registration form fields (camper/teacher/volunteer)
  campers      Camper[] // Organization has many camper profiles
  camps        Camp[] // Organization has many camps
  activeCampId String? // Reference to the active camp
  activeCamp   Camp?       @relation("ActiveCamp", fields: [activeCampId], references: [id])
  settings     Json? // Holds admin settings such as age range, cutoff date, etc.
  registrationDeclarations RegistrationDeclaration[]
  registrationConfig       RegistrationConfig?
  branding                 OrganizationBranding?
  emailCampaigns           EmailCampaign[]
  savedAudiences           SavedAudience[]
  approvalWorkflow String  @default("SINGLE_STEP") // SINGLE_STEP | TWO_STEP
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// Campus: permanent church branch/organization structure. Identity only -
// never holds camp-operational fields like capacity/quota. See Venue for
// the temporary, per-Camp physical site those belong to.
model Campus {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  address      String
  city         String
  state        String?
  zipCode      String?
  country      String
  pastor       String?
  phone        String?
  email        String?
  active       Boolean @default(true)
  signupOpen   Boolean @default(true)
  campusCode   String? // short code embedded in registration numbers
  displayOrder Int     @default(0) // order in dropdowns/lists

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  reps           User[]         @relation("CampusReps")
  users          User[]         @relation("UserCampus")
  campers        Camper[]
  registrations  Registration[]
  signupLinks    SignupLink[]

  registrationCounters RegistrationCounter[]
  preferredByStaff     StaffProfile[]        @relation("PreferredStaffCampus")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Uniqueness on (organizationId, name) is enforced by a partial unique index
  // (WHERE "deletedAt" IS NULL) added by hand in the migration SQL, not by
  // Prisma's schema-level @@unique — see the soft-delete migration notes.
  @@index([organizationId, name])
  @@index([deletedAt])
}

// Venue: physical camp site, scoped to exactly one Camp (not reused across
// camps - a new Venue row is created each time, even for the same physical
// facility). Holds all camp-operational/capacity fields that used to live
// on Location.
model Venue {
  id           String  @id @default(cuid())
  name         String
  address      String?
  capacity     Int?
  contactPhone String?
  contactEmail String?
  gpsLat       Float?
  gpsLng       Float?
  mapsUrl      String?
  notes        String?

  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId String

  code         String?
  quota        Int     @default(0)
  signupOpen   Boolean @default(true)
  visible      Boolean @default(true)
  fullBehavior String  @default("CLOSE") // CLOSE | PENDING_OK | REDIRECT

  registrations      Registration[]
  hostels            Hostel[]
  assignedStaff      StaffProfile[]      @relation("AssignedStaffVenue")
  attendanceSessions AttendanceSession[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([campId, name])
  @@index([deletedAt])
}

model Permission {
  id        String         @id @default(cuid())
  type      PermissionType
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, type])
}

model FormField {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  audience       FormFieldAudience
  source         FormFieldSource     @default(CUSTOM)
  systemKey      String? // set only when source = SYSTEM; names the bound profile column
  name           String // stable key: systemKey for SYSTEM, admin-chosen slug for CUSTOM
  label          String
  type           ProfileFieldType
  required       Boolean             @default(false)
  visible        Boolean             @default(true)
  options        String? // JSON string for select/multi-select/radio options
  helpText       String?
  placeholder    String?
  defaultValue   String?
  groupLabel     String? // visual section header in the wizard
  sortOrder      Int                 @default(0)
  validation     Json?
  profileValues  ProfileFieldValue[]
  staffValues    StaffFieldValue[]
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([organizationId, audience, name])
  @@index([organizationId, audience, sortOrder])
  @@index([deletedAt])
}

model Camper {
  id            String    @id @default(cuid())
  name          String
  firstName     String?
  middleName    String?
  lastName      String?
  preferredName String?
  dateOfBirth   DateTime? // Date of birth field
  gender        String? // Gender field
  photoUrl      String?

  // Medical / Emergency (PRD Part 3 §8)
  allergies             String?
  medicalConditions     String?
  medications           String?
  dietaryRestrictions   String?
  emergencyContactName  String?
  emergencyContactPhone String?
  relationship          String?
  // Structured medical profile for allocation engine v2
  medicalProfile        Json? // { conditions[], mobilityNeeds, specialAccommodations, dietaryRestrictions }

  // Contact Details
  parentPhone       String?
  teenPhone         String?
  homeAddressStreet String?
  homeAddressCity   String?
  homeAddressState  String?
  homeAddressZip    String?

  // Education / Church
  school       String?
  currentClass String?
  church       String?
  pastor       String?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  // Denormalized "last known" home campus - non-authoritative convenience field.
  // Prefer Registration.campusId for historical accuracy; this is kept in sync
  // on every registration-affecting mutation (see registration engine) because
  // existing UI (camper list filters, home-campus display) reads it directly.
  homeCampus     Campus?             @relation(fields: [homeCampusId], references: [id])
  homeCampusId   String?
  fieldValues    ProfileFieldValue[]
  registrations  Registration[] // Profile can have many registrations
  documents      Document[]
  active         Boolean             @default(true)
  dobApproved    Boolean             @default(false)
  birthCert      String? // URL to uploaded birth certificate
  deletedAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([deletedAt])
}

model ProfileFieldValue {
  id        String    @id @default(cuid())
  value     String // Stored as string, converted based on field type
  field     FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId   String
  camper    Camper    @relation(fields: [camperId], references: [id], onDelete: Cascade)
  camperId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([fieldId, camperId])
}

// Camp: a temporary camp event (e.g. "Teen Camp 2025"). Year is one
// attribute of the Camp, not the entity itself - multiple Camps can occur
// within the same calendar year.
model Camp {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String
  year                 Int
  startDate            DateTime
  endDate              DateTime
  active               Boolean               @default(false)
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId       String
  venues               Venue[]
  registrations        Registration[]
  activeForOrgs        Organization[]        @relation("ActiveCamp")
  signupLinks          SignupLink[]
  documentRequirements DocumentRequirement[]
  registrationCounters RegistrationCounter[]
  staffSignupLinks     StaffSignupLink[]
  staffProfiles        StaffProfile[]
  attendanceSessions   AttendanceSession[]
  incidentReports      IncidentReport[]
  medicalVisits        MedicalVisit[]
  mealDistributions    MealDistribution[]
  scanEvents           ScanEvent[]
  departments          Department[]
  positions            Position[]

  // Tribe Allocation (PRD Part 4A)
  tribeAllocationEnabled Boolean  @default(false)
  tribeAllocationMode    String   @default("MANUAL") // MANUAL | AUTOMATIC | HYBRID
  tribeAllocationRules   Json?    // [{ criterion, enabled }] — legacy flat format; mapped to v2 internally
  targetTribeSize        Int?     // Optional override; otherwise computed from approved_registrations / active_tribes
  tribeAllocationPresets Json?    // [{ name, description, rules }]
  tribes                 Tribe[]
  tribeAllocationLogs    TribeAllocationLog[]

  // Bed Allocation (mirrors Tribe Allocation above) — gender-match to Hostel.gender
  // is always a hard filter in the engine, not a toggleable rule here.
  bedAllocationEnabled Boolean @default(false)
  bedAllocationRules   Json? // ordered array: [{ criterion: "AGE_GROUP"|"GROUP_TOGETHER"|"CAMPUS_TOGETHER"|"POPULATION_BALANCE", enabled: true }]

  // Camp Configuration (PRD Part 2)
  theme                String?
  description          String?
  bannerUrl            String?
  logoUrl              String?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  arrivalDate          DateTime?
  departureDate        DateTime?
  minAge               Int?
  maxAge               Int?
  ageCutoffDate        DateTime?
  maxRegistrations     Int? // null = unlimited
  capacityBehavior     String    @default("CLOSE") // CLOSE | WAITLIST | PENDING_OK
  approvalMode         String    @default("MANUAL") // MANUAL | AUTO
  allowResubmission    Boolean   @default(true)
  status               String    @default("DRAFT") // DRAFT | OPEN | CLOSED | ARCHIVED
  orgCode              String?
  remindersHtml        String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique indexes (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([organizationId, name])
  @@index([organizationId, slug])
  @@index([deletedAt])
}

model SignupLink {
  id        String   @id @default(cuid())
  token     String   @unique // The unique token for the URL
  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  campusId  String
  camp      Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId    String
  active    Boolean  @default(true)
  quota     Int      @default(0) // 0 = unlimited
  quotaFullBehavior String @default("CLOSE") // CLOSE | WAITLIST
  clicks    SignupLinkClick[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campusId, campId])
}

model OTP {
  email     String   @id
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
}

model Registration {
  id              String             @id @default(cuid())
  status          RegistrationStatus @default(DRAFT)
  notes           String?
  camper          Camper             @relation(fields: [camperId], references: [id], onDelete: Cascade)
  camperId        String
  camp            Camp               @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId          String
  campus          Campus             @relation(fields: [campusId], references: [id])
  campusId        String
  // Nullable: assigned later at approval/allocation time, not at signup.
  // Parents pick a Campus at signup; Venue assignment happens once camp
  // operations knows where this camper is physically headed.
  venue           Venue?             @relation(fields: [venueId], references: [id])
  venueId         String?
  venueAssignedAt DateTime?
  parentConsent   String? // URL to uploaded parent consent form
  published       Boolean            @default(false)

  // Registration Engine fields (PRD Part 4)
  registrationNumber String?   @unique
  qrToken            String?   @unique
  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectionReason    String?
  correctionRequest  String?
  reviewerId         String?
  checkedInAt        DateTime?
  checkedInById      String?
  checkedOutAt       DateTime?
  checkedOutById     String?
  checkoutCollectorName String?
  checkoutCollectorRelationship String?
  checkoutDetails    Json?
  internalNotes      Json? // [{authorId, text, at}]
  communicationLog   Json? // {"ACCEPTANCE":"SENT"|"NOT_SENT","REJECTION":"SENT"|"NOT_SENT","CORRECTION":"SENT"|"NOT_SENT","WAITLIST":"SENT"|"NOT_SENT"}
  fieldChangeLog     Json? // [{field, previousValue, newValue, changedAt, changedById}]
  waitlistPosition   Int?

  // Tribe Allocation (PRD Part 4A)
  tribe                 Tribe?    @relation(fields: [tribeId], references: [id])
  tribeId               String?
  tribeAssignedAt       DateTime?
  tribeAssignmentMethod String?   // AUTOMATIC | MANUAL | HYBRID_OVERRIDE
  isTribeLocked         Boolean   @default(false)
  tribeAllocationLogs   TribeAllocationLog[]

  // Accommodation (Camp Structure module)
  room   Room?   @relation(fields: [roomId], references: [id])
  roomId String?
  bed    Bed?

  documents          Document[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  review             RegistrationReview?
  teacherAssignments TeacherCamperAssignment[]
  attendanceRecords  AttendanceRecord[]
  incidentReports    IncidentReport[]
  medicalVisits      MedicalVisit[]
  mealDistributions  MealDistribution[]
  scanEvents         ScanEvent[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration —
  // lets a camper re-register for the same camp after a prior registration was soft-deleted.
  @@index([camperId, campId])
  @@index([campusId, status])
  @@index([venueId, status])
  @@index([campId, status])
  @@index([deletedAt])
}

// ─── Registration Review Workflow ────────────────────────────────────────────

model RegistrationReview {
  id                 String       @id @default(cuid())
  registrationId     String       @unique
  registration       Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  // Verification (two-step only)
  assignedToId       String?      // userId of verifier
  verificationStatus String       @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED
  verifiedById       String?      // userId who completed verification
  recommendation     String?      // APPROVE | REJECT | CORRECTION
  reviewNotes        String?      // verifier's private notes

  // Admin decision (populated on final status change)
  adminDecision      String?      // APPROVE | REJECT | WAITLIST | CORRECTION | CANCEL | ARCHIVE
  decidedById        String?
  decidedAt          DateTime?

  // Timestamps
  assignedAt         DateTime?
  verifiedAt         DateTime?
  completedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model DocumentRequirement {
  id              String     @id @default(cuid())
  camp            Camp       @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId          String
  name            String
  description     String?
  required        Boolean    @default(true)
  acceptedFormats String     @default("jpg,png")
  maxSizeMb       Int        @default(2)
  scope           String     @default("CAMPER") // CAMPER | REGISTRATION
  sortOrder       Int        @default(0)
  documents       Document[]
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([deletedAt])
}

model Document {
  id              String               @id @default(cuid())
  requirement     DocumentRequirement? @relation(fields: [requirementId], references: [id])
  requirementId   String?
  camper          Camper?              @relation(fields: [camperId], references: [id], onDelete: Cascade)
  camperId        String?
  registration    Registration?        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId  String?
  url             String
  fileName        String
  fileType        String
  fileSize        Int
  status          String               @default("UPLOADED") // UPLOADED | APPROVED | REJECTED
  rejectionReason String?
  uploadedById    String
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  documentActions DocumentAction[]

  @@index([deletedAt])
}

model DocumentAction {
  id              String   @id @default(cuid())
  documentId      String
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status          String   @default("REQUIRES_ACTION") // REQUIRES_ACTION | RESOLVED
  reason          String
  requestedById   String
  requestedAt     DateTime @default(now())
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionType  String? // PARENT_UPLOAD | REP_UPLOAD | ADMIN_OVERRIDE
  replacementForId String? // links to the document this action replaced, for history
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([documentId])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String?
  actorId        String?
  action         String
  previousValue  Json?
  newValue       Json?
  createdAt      DateTime      @default(now())

  @@index([registrationId])
  @@index([organizationId, createdAt])
}

model Notification {
  id             String        @id @default(cuid())
  organizationId String
  userId         String
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String?
  channel        String        @default("IN_APP") // IN_APP | EMAIL
  title          String
  body           String
  status         String        @default("QUEUED") // QUEUED | SENT | DELIVERED | FAILED
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId, readAt])
}

model Tribe {
  id                 String              @id @default(cuid())
  camp               Camp                @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId             String
  name               String
  code               String?             // Short code e.g. AGP, BER, ZOE
  color              String?             // HEX colour e.g. #E53935
  displayOrder       Int                 @default(0) // Controls sort order throughout the app
  logoUrl            String?
  bannerUrl          String?             // Banner image for tribe dashboard / digital pass
  description        String?
  meaning            String?             // Short meaning or theme e.g. "Unconditional Love"
  motto              String?             // e.g. "Love Never Fails"
  scripture          String?             // e.g. "John 13:34"
  gender             String?             // MALE | FEMALE | MIXED
  ageRange           String?             // e.g. "10-12" | "All Ages"
  allocationStrategy String              @default("MANUAL") // MANUAL | AUTOMATIC | INVITE_ONLY
  maxCapacity        Int?
  isAllocationLocked Boolean             @default(false)
  status             String              @default("ACTIVE") // ACTIVE | INACTIVE
  registrations      Registration[]
  allocationLogs     TribeAllocationLog[]
  preferredByStaff   StaffProfile[]      @relation("PreferredTribe")
  assignedStaff      StaffProfile[]      @relation("AssignedStaffTribe")
  attendanceSessions AttendanceSession[]
  points             Int                 @default(0)
  pointsLog          TribePointsLog[]
  deletedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([campId, name])
  @@index([campId, code])
  @@index([deletedAt])
}

model SideEffect {
  id                    String   @id @default(cuid())
  registrationId        String?
  broadcastRecipientId  String?
  campaignId            String?
  campaign              EmailCampaign? @relation(fields: [campaignId], references: [id])
  organizationId        String?
  deliverySource        String?  // REGISTRATION_APPROVED | CAMPAIGN | OTP | WELCOME | STAFF_APPROVED | BROADCAST_SEND | ...
  recipientEmail        String?  // for display in queue UI
  recipientType         String?  // PARENT | TEACHER | VOLUNTEER | CAMPUS_REP | ADMIN
  txId                  String?  // Resend/history log id for tracking
  type                  String   // REGISTRATION_APPROVED | BROADCAST_SEND | CAMPAIGN_SEND | ...
  status                String   @default("QUEUED") // QUEUED | DONE | FAILED | CANCELLED
  attempts              Int      @default(0)
  lastError             String?
  runAfter              DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, runAfter])
  @@index([campaignId])
  @@index([organizationId, status])
  @@index([recipientEmail])
}

model RegistrationCounter {
  id       String @id @default(cuid())
  camp     Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId   String
  campus   Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)
  campusId String
  value    Int    @default(0)

  @@unique([campId, campusId])
}

// ─── Teacher & Volunteer (Staff) Modules ────────────────────────────────────

enum StaffType {
  TEACHER
  VOLUNTEER
}

enum StaffStatus {
  PENDING
  APPROVED
  REJECTED
  DEACTIVATED
}

model StaffSignupLink {
  id             String    @id @default(cuid())
  token          String    @unique
  type           StaffType
  camp           Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId         String
  organizationId String
  active         Boolean   @default(true)
  clicks         StaffSignupLinkClick[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([campId, type])
}

model StaffFieldValue {
  id             String       @id @default(cuid())
  value          String
  field          FormField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId        String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  staffProfileId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([fieldId, staffProfileId])
}

model StaffProfile {
  id             String      @id @default(cuid())
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organizationId String
  camp           Camp        @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId         String
  type           StaffType
  status         StaffStatus @default(PENDING)

  // Personal
  firstName     String
  lastName      String
  preferredName String?
  gender        String?
  dateOfBirth   DateTime?
  phone         String
  email         String
  photoUrl      String?

  // Church
  church           String?
  churchDepartment String?
  yearsServing     String?
  workerStatus     String?

  // Camp preferences
  previousCampExperience String?
  areasOfStrength        String?
  preferredAgeGroup      String?
  preferredCampus        Campus? @relation("PreferredStaffCampus", fields: [preferredCampusId], references: [id])
  preferredCampusId      String?
  preferredTribe         Tribe?  @relation("PreferredTribe", fields: [preferredTribeId], references: [id])
  preferredTribeId       String?

  // Volunteer-specific
  volunteerCategory String?
  teams             String[]

  // Shared
  skills                       String[]
  availability                 String?
  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?
  medicalConditions            String?
  allergies                    String?

  // Review
  submittedAt     DateTime  @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  reviewerId      String?
  deactivatedAt   DateTime?

  // Assignment (post-approval)
  assignedVenue   Venue?  @relation("AssignedStaffVenue", fields: [assignedVenueId], references: [id])
  assignedVenueId String?
  assignedTribe   Tribe?  @relation("AssignedStaffTribe", fields: [assignedTribeId], references: [id])
  assignedTribeId String?

  // Camp Structure: department & position flags
  department         Department? @relation(fields: [departmentId], references: [id])
  departmentId       String?
  isDepartmentHead   Boolean     @default(false)
  isAssistantHead    Boolean     @default(false)
  isCampMonitor      Boolean     @default(false)
  isAssistantMonitor Boolean     @default(false)

  // Camp Structure: reporting hierarchy (exactly one of these two is set, enforced in the router)
  reportsTo       StaffProfile?  @relation("ReportsTo", fields: [reportsToId], references: [id])
  reportsToId     String?
  directReports   StaffProfile[] @relation("ReportsTo")
  reportsToUser   User?          @relation("StaffReportsToUser", fields: [reportsToUserId], references: [id])
  reportsToUserId String?

  // Camp Structure: teacher/volunteer accommodation assignment
  assignedHostel   Hostel? @relation("AssignedStaffHostel", fields: [assignedHostelId], references: [id])
  assignedHostelId String?
  assignedRoom     Room?   @relation("AssignedStaffRoom", fields: [assignedRoomId], references: [id])
  assignedRoomId   String?
  assignedBed      Bed?    @relation("AssignedStaffBed")

  fieldValues         StaffFieldValue[]
  camperAssignments   TeacherCamperAssignment[]
  positionAssignments PositionAssignment[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([userId, campId])
  @@index([organizationId, type, status])
  @@index([deletedAt])
}

model TeacherCamperAssignment {
  id             String       @id @default(cuid())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  staffProfileId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  createdAt      DateTime     @default(now())

  @@unique([staffProfileId, registrationId])
}

model AttendanceSession {
  id          String             @id @default(cuid())
  camp        Camp               @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId      String
  venue       Venue?             @relation(fields: [venueId], references: [id])
  venueId     String?
  tribe       Tribe?             @relation(fields: [tribeId], references: [id])
  tribeId     String?
  name        String
  date        DateTime
  createdById String
  records     AttendanceRecord[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model AttendanceRecord {
  id             String            @id @default(cuid())
  session        AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String
  registration   Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  status         String // PRESENT | ABSENT | LATE
  recordedById   String
  recordedAt     DateTime          @default(now())

  @@unique([sessionId, registrationId])
}

model IncidentReport {
  id             String        @id @default(cuid())
  organizationId String
  camp           Camp          @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId         String
  registration   Registration? @relation(fields: [registrationId], references: [id])
  registrationId String?
  reportedById   String
  severity       String // LOW | MEDIUM | HIGH
  title          String
  description    String
  status         String        @default("OPEN") // OPEN | RESOLVED
  createdAt      DateTime      @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
}

model MedicalVisit {
  id             String       @id @default(cuid())
  organizationId String
  camp           Camp         @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId         String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  recordedById   String
  complaint      String
  treatment      String?
  notes          String?
  visitedAt      DateTime     @default(now())
}

model MealDistribution {
  id             String       @id @default(cuid())
  camp           Camp         @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId         String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  meal           String // BREAKFAST | LUNCH | DINNER
  date           DateTime     @db.Date
  servedById     String
  servedAt       DateTime     @default(now())

  @@unique([registrationId, meal, date])
}

// ─── Camp Structure & Organogram ────────────────────────────────────────────

model Department {
  id               String                   @id @default(cuid())
  organizationId   String
  camp             Camp?                    @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId           String? // per-camp instance, matching Tribe; null = org-wide template
  name             String
  description      String?
  responsibilities String[]                 @default([])
  status           String                   @default("ACTIVE") // ACTIVE | INACTIVE
  maxCapacity      Int? // null = unlimited; mirrors Tribe.maxCapacity
  positions        Position[]
  announcements    DepartmentAnnouncement[]
  documents        DepartmentDocument[]
  activityLogs     DepartmentActivityLog[]
  staff            StaffProfile[]
  deletedAt        DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([organizationId, campId, name])
  @@index([deletedAt])
}

model Hostel {
  id             String         @id @default(cuid())
  organizationId String
  venue          Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  venueId        String
  name           String // e.g. "Male Hostel A"
  gender         String? // MALE | FEMALE | MIXED
  rooms          Room[]
  staffAssigned  StaffProfile[] @relation("AssignedStaffHostel")
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([venueId, name])
  @@index([deletedAt])
}

model Room {
  id            String         @id @default(cuid())
  hostel        Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hostelId      String
  name          String // e.g. "Room 12"
  capacity      Int?
  beds          Bed[]
  registrations Registration[]
  staffAssigned StaffProfile[] @relation("AssignedStaffRoom")
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([hostelId, name])
  @@index([deletedAt])
}

model Bed {
  id             String        @id @default(cuid())
  room           Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId         String
  label          String // e.g. "Bed 1"
  status         BedStatus     @default(AVAILABLE)
  registration   Registration? @relation(fields: [registrationId], references: [id])
  registrationId String?       @unique
  // Exclusive alternative to registrationId — a bed holds one camper OR one
  // staff member at a time, enforced in the assignment mutations, not the DB.
  staffProfile   StaffProfile? @relation("AssignedStaffBed", fields: [staffProfileId], references: [id])
  staffProfileId String?       @unique
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Partial unique index (WHERE "deletedAt" IS NULL) added by hand in the migration.
  @@index([roomId, label])
  @@index([deletedAt])
}

model TribePointsLog {
  id        String   @id @default(cuid())
  tribe     Tribe    @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  tribeId   String
  delta     Int
  reason    String?
  actorId   String
  createdAt DateTime @default(now())
}

model TribeAllocationLog {
  id               String       @id @default(cuid())
  registration     Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId   String
  tribe            Tribe        @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  tribeId          String
  camp             Camp         @relation(fields: [campId], references: [id], onDelete: Cascade)
  campId           String
  engineVersion    String
  allocationMode   String
  rulesetVersion   String
  rulesetSnapshot  Json
  scoreBreakdown   Json
  reasons          Json
  wasOverridden    Boolean      @default(false)
  overriddenById   String?
  overriddenAt     DateTime?
  actorId          String?
  createdAt        DateTime     @default(now())
}

model RegistrationDeclaration {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  required       Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, sortOrder])
}

model RegistrationConfig {
  id                     String       @id @default(cuid())
  organizationId         String       @unique
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  consentFormTitle       String?
  consentFormDescription String?
  consentFormSampleUrl   String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model Position {
  id               String               @id @default(cuid())
  name             String               // e.g. "Camp Director", "Registration Head"
  campId           String
  camp             Camp                 @relation(fields: [campId], references: [id], onDelete: Cascade)
  departmentId     String?              // Nullable for top-level admin roles outside departments
  department       Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  parentPositionId String?
  parentPosition   Position?            @relation("PositionHierarchy", fields: [parentPositionId], references: [id], onDelete: SetNull)
  childPositions   Position[]           @relation("PositionHierarchy")
  displayOrder     Int                  @default(0)
  status           String               @default("ACTIVE") // ACTIVE | ARCHIVED
  assignments      PositionAssignment[]
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([campId])
  @@index([departmentId])
  @@index([parentPositionId])
  @@index([deletedAt])
}

model PositionAssignment {
  id         String       @id @default(cuid())
  positionId String
  position   Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  staffId    String
  staff      StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate  DateTime     @default(now())
  endDate    DateTime?
  isCurrent  Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([positionId])
  @@index([staffId])
  @@index([isCurrent])
}

model DepartmentAnnouncement {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  title        String
  content      String
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

model DepartmentDocument {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  url          String
  fileType     String
  fileSize     Int
  uploadedById String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

model DepartmentActivityLog {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  action       String     // STAFF_ASSIGNED, STAFF_REMOVED, HEAD_CHANGED, DEPT_RENAMED, DEPT_ARCHIVED
  actorId      String
  details      Json?
  createdAt    DateTime   @default(now())

  @@index([departmentId])
}

// ─── Communication Center ──────────────────────────────────────────────────

model EmailEventConfig {
  id             String         @id @default(cuid())
  organizationId String
  event          String         // REGISTRATION_APPROVED | REGISTRATION_REJECTED | REGISTRATION_SUBMITTED | CORRECTION_REQUESTED | REGISTRATION_WAITLISTED | STAFF_APPROVED | STAFF_REJECTED | OTP_EMAIL | WELCOME_EMAIL
  enabled        Boolean        @default(true)
  templateId     String?
  template       EmailTemplate? @relation(fields: [templateId], references: [id])
  channels       Json           @default("[\"EMAIL\", \"IN_APP\"]")
  recipients     Json           @default("[\"PARENT\"]")
  senderMode     String         @default("ORG_SLUG")
  customFromLocalPart String?
  replyTo        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, event])
  @@index([organizationId])
}

model EmailTemplate {
  id             String             @id @default(cuid())
  organizationId String
  name           String             // "Registration Approved", "Welcome", etc.
  description    String?
  subject        String             // "You're approved for {{camp_name}}!"
  previewText    String?
  content        Json               // TipTap JSON
  isDefault      Boolean            @default(false)
  active         Boolean            @default(true)
  eventConfigs   EmailEventConfig[] // Events using this template
  campaigns      EmailCampaign[]
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, name])
  @@index([deletedAt])
}

model OrganizationBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String       @default("#E67E22")
  accentColor    String       @default("#E67E22")
  buttonColor    String       @default("#E67E22")
  headerImageUrl String?
  senderName     String?      // Display name for email sender (e.g. "Grace Community Church")
  footerText     String?
  supportEmail   String?
  supportPhone   String?
  websiteUrl     String?
  facebookUrl    String?
  instagramUrl   String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Broadcast {
  id             String                @id @default(cuid())
  organizationId String
  title          String
  subject        String
  body           Json                  // TipTap JSON
  audience       String                // PARENTS | TEACHERS | VOLUNTEERS | ALL
  campId         String?
  campusId       String?
  status         String                @default("DRAFT") // DRAFT | SENDING | COMPLETED | FAILED
  senderMode     String                @default("ORG_SLUG")
  customFromLocalPart String?
  replyTo        String?
  createdById    String
  sentAt         DateTime?
  completedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  recipients     BroadcastRecipient[]

  @@index([organizationId, status])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  recipientId String    // userId
  email       String
  status      String    @default("QUEUED") // QUEUED | SENT | FAILED
  sideEffectId String?
  queuedAt    DateTime  @default(now())
  sentAt      DateTime?
  failedAt    DateTime?
  error       String?
  readAt      DateTime?
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([broadcastId, status])
  @@index([recipientId, readAt])
  @@index([recipientId, pinned])
}

// ─── Campaigns (replaces Broadcast) ──────────────────────────────────────────

model EmailCampaign {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  subject          String
  previewText      String?
  templateId       String?
  template         EmailTemplate?  @relation(fields: [templateId], references: [id])
  body             Json            // TipTap JSON
  status           String          @default("DRAFT") // DRAFT | SCHEDULED | QUEUED | SENDING | COMPLETED | PAUSED | CANCELLED | FAILED
  scheduledFor     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  recipientCount   Int             @default(0)
  audienceFilter   Json?           // SavedAudience filter definition (inline or reference)
  savedAudienceId  String?
  savedAudience    SavedAudience?  @relation(fields: [savedAudienceId], references: [id])
  senderMode       String          @default("ORG_SLUG")
  customFromLocalPart String?
  replyTo          String?
  attachments      Json?           // [{ url, fileName, fileType, fileSize }]
  createdById      String
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  recipients       EmailRecipient[]
  sideEffects      SideEffect[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([deletedAt])
}

model EmailRecipient {
  id               String         @id @default(cuid())
  campaignId       String?
  campaign         EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  organizationId   String?
  userId           String
  registrationId   String?
  email            String
  recipientType    String         // PARENT | TEACHER | VOLUNTEER | CAMPUS_REP | ADMIN
  deliveryStatus   String         @default("QUEUED") // QUEUED | SENT | DELIVERED | OPENED | CLICKED | BOUNCED | FAILED | CANCELLED
  deliverySource   String?        // REGISTRATION_APPROVED | CAMPAIGN | OTP | WELCOME | STAFF_APPROVED | ...
  subject          String?        // email subject line
  queuedAt         DateTime       @default(now())
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  bouncedAt        DateTime?
  failedReason     String?
  retryCount       Int            @default(0)
  providerMessageId String?
  sideEffectId     String?
  readAt           DateTime?      // inbox read tracking
  pinned           Boolean        @default(false) // inbox pin
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([campaignId, deliveryStatus])
  @@index([organizationId, createdAt])
  @@index([userId, readAt])
  @@index([userId, pinned])
  @@index([email])
  @@index([registrationId])
  @@index([deliverySource])
}

model SavedAudience {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  filterDefinition Json            // { recipientType, filters: { registrationStatus?, campId?, campusId?, ... } }
  createdById      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  campaigns        EmailCampaign[]

  @@index([organizationId])
}

model EmailAuditLog {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String?
  action           String   // CAMPAIGN_SENT | CAMPAIGN_CANCELLED | RETRY_TRIGGERED | QUEUE_PAUSED | QUEUE_RESUMED | CAMPAIGN_DELETED
  targetType       String?  // CAMPAIGN | QUEUE | RECIPIENT | TEMPLATE | EVENT_CONFIG
  targetId         String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([targetType, targetId])
}

model ScanEvent {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  campId         String?
  camp           Camp?        @relation(fields: [campId], references: [id], onDelete: Cascade)
  station        String       // e.g. "Lekki Pickup Point", "Camp Arrival", "Breakfast", "Checkout", "Identity Lookup"
  timestamp      DateTime     @default(now())
  volunteer      User         @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  volunteerId    String
  device         String?
  location       String?
  result         String       // "SUCCESS" | "DUPLICATE" | "ERROR"
  metadata       Json?        // Stores collector name, relationship, offline timestamp details, etc.
  
  @@index([registrationId])
  @@index([campId])
  @@index([timestamp])
}

// ─── Signup Link Click Tracking ───────────────────────────────────────────────

model SignupLinkClick {
  id           String     @id @default(cuid())
  signupLink   SignupLink @relation(fields: [signupLinkId], references: [id], onDelete: Cascade)
  signupLinkId String
  userId       String?    // null = anonymous; populated after the visitor logs in/registers
  ipAddress    String?
  userAgent    String?
  clickedAt    DateTime   @default(now())

  @@index([signupLinkId])
  @@index([clickedAt])
}

model StaffSignupLinkClick {
  id                String          @id @default(cuid())
  staffSignupLink   StaffSignupLink @relation(fields: [staffSignupLinkId], references: [id], onDelete: Cascade)
  staffSignupLinkId String
  userId            String?
  ipAddress         String?
  userAgent         String?
  clickedAt         DateTime        @default(now())

  @@index([staffSignupLinkId])
  @@index([clickedAt])
}
