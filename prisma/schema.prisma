// This is your Prisma schema file, simplified for the new requirements

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  LOCATION_ADMIN
  BASE_USER
  TEACHER
  VOLUNTEER
}

enum PermissionType {
  CREATE_LOCATION
  READ_LOCATION
  UPDATE_LOCATION
  DELETE_LOCATION
  MANAGE_ADMINS
  MANAGE_LOCATION_ADMINS
  VIEW_ANALYTICS
}

enum ProfileFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  CHECKBOX
  SELECT
  MULTI_SELECT
  RADIO
  FILE
}

enum RegistrationStatus {
  DRAFT
  SUBMITTED
  PENDING
  REQUIRES_ACTION
  APPROVED
  REJECTED
  WAITLISTED
  CANCELLED
  CHECKED_IN
  COMPLETED
  ARCHIVED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  password         String
  role             UserRole
  firstName        String?
  lastName         String?
  phone            String?
  active           Boolean         @default(true)
  organization     Organization?   @relation(fields: [organizationId], references: [id])
  organizationId   String?
  location         Location?       @relation("UserLocation", fields: [locationId], references: [id])
  locationId       String?
  managedLocations Location[]      @relation("LocationAdmins")
  permissions      Permission[]
  camperProfiles   CamperProfile[] // User can have multiple camper profiles
  staffProfiles    StaffProfile[]
  reportsFromStaff StaffProfile[]  @relation("StaffReportsToUser")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Organization {
  id             String          @id @default(cuid())
  name           String          @unique
  users          User[]
  locations      Location[]
  profileFields  ProfileField[] // Organization defines profile fields
  camperProfiles CamperProfile[] // Organization has many camper profiles
  years          Year[] // Organization has many years
  activeYearId   String? // Reference to the active year
  activeYear     Year?           @relation("ActiveYear", fields: [activeYearId], references: [id])
  settings       Json? // Holds admin settings such as age range, cutoff date, etc.
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Location {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  address        String
  city           String
  state          String?
  zipCode        String?
  country        String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  admins         User[]          @relation("LocationAdmins")
  users          User[]          @relation("UserLocation")
  camperProfiles CamperProfile[] // Location can have many camper profiles
  registrations  Registration[] // Location can have many registrations
  signupLinks    SignupLink[] // Location can have many signup links
  quota          Int             @default(0)
  signupOpen     Boolean         @default(true)

  // Centre Configuration (PRD Part 2 §8)
  code         String?
  contactPhone String?
  contactEmail String?
  mapsUrl      String?
  visible      Boolean @default(true)
  fullBehavior String  @default("CLOSE") // CLOSE | PENDING_OK | REDIRECT

  registrationCounters RegistrationCounter[]
  preferredByStaff     StaffProfile[]        @relation("PreferredStaffLocation")
  assignedStaff        StaffProfile[]        @relation("AssignedStaffLocation")
  hostels              Hostel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
}

model Permission {
  id        String         @id @default(cuid())
  type      PermissionType
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, type])
}

model ProfileField {
  id             String              @id @default(cuid())
  name           String
  label          String
  type           ProfileFieldType
  required       Boolean             @default(false)
  options        String? // JSON string for select options
  helpText       String?
  placeholder    String?
  defaultValue   String?
  sortOrder      Int                 @default(0)
  validation     Json?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  fieldValues    ProfileFieldValue[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, name])
}

model CamperProfile {
  id            String    @id @default(cuid())
  name          String
  firstName     String?
  middleName    String?
  lastName      String?
  preferredName String?
  dateOfBirth   DateTime? // Date of birth field
  gender        String? // Gender field
  photoUrl      String?

  // Medical / Emergency (PRD Part 3 §8)
  allergies             String?
  medicalConditions     String?
  medications           String?
  dietaryRestrictions   String?
  emergencyContactName  String?
  emergencyContactPhone String?
  relationship          String?

  // Education / Church
  school       String?
  currentClass String?
  church       String?
  pastor       String?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  location       Location?           @relation(fields: [locationId], references: [id])
  locationId     String?
  fieldValues    ProfileFieldValue[]
  registrations  Registration[] // Profile can have many registrations
  documents      Document[]
  active         Boolean             @default(true)
  dobApproved    Boolean             @default(false)
  birthCert      String? // URL to uploaded birth certificate
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ProfileFieldValue {
  id              String        @id @default(cuid())
  value           String // Stored as string, converted based on field type
  field           ProfileField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId         String
  camperProfile   CamperProfile @relation(fields: [camperProfileId], references: [id], onDelete: Cascade)
  camperProfileId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([fieldId, camperProfileId])
}

model Year {
  id                   String                @id @default(cuid())
  name                 String // e.g., "2025", "Summer 2025"
  slug                 String // URL-friendly version of name, e.g., "summer-2025"
  startDate            DateTime
  endDate              DateTime
  active               Boolean               @default(false)
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId       String
  registrations        Registration[] // Year can have many registrations
  activeForOrgs        Organization[]        @relation("ActiveYear")
  signupLinks          SignupLink[] // Year can have many signup links
  documentRequirements DocumentRequirement[]
  registrationCounters RegistrationCounter[]
  staffSignupLinks     StaffSignupLink[]
  staffProfiles        StaffProfile[]
  attendanceSessions   AttendanceSession[]
  incidentReports      IncidentReport[]
  medicalVisits        MedicalVisit[]
  mealDistributions    MealDistribution[]

  // Tribe Allocation (PRD Part 4A)
  tribeAllocationEnabled Boolean @default(false)
  tribeAllocationMode    String  @default("MANUAL") // MANUAL | AUTOMATIC | HYBRID
  tribeAllocationRules   Json? // ordered array: [{ criterion: "POPULATION"|"GENDER"|"AGE"|"CENTRE"|"CHURCH"|"SCHOOL"|"SIBLINGS_TOGETHER"|"SIBLINGS_APART"|"RETURNING_CAMPER", enabled: true }]
  tribes                 Tribe[]

  // Camp Configuration (PRD Part 2)
  theme                String?
  description          String?
  bannerUrl            String?
  logoUrl              String?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  arrivalDate          DateTime?
  departureDate        DateTime?
  minAge               Int?
  maxAge               Int?
  ageCutoffDate        DateTime?
  maxRegistrations     Int? // null = unlimited
  capacityBehavior     String    @default("CLOSE") // CLOSE | WAITLIST | PENDING_OK
  approvalMode         String    @default("MANUAL") // MANUAL | AUTO
  allowResubmission    Boolean   @default(true)
  status               String    @default("DRAFT") // DRAFT | OPEN | CLOSED | ARCHIVED
  orgCode              String?
  remindersHtml        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@unique([organizationId, slug])
}

model SignupLink {
  id         String   @id @default(cuid())
  token      String   @unique // The unique token for the URL
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String
  year       Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([locationId, yearId])
}

model OTP {
  email     String   @id
  code      String
  expiresAt DateTime
  attempts  Int      @default(0)
}

model Registration {
  id              String             @id @default(cuid())
  status          RegistrationStatus @default(DRAFT)
  notes           String?
  camperProfile   CamperProfile      @relation(fields: [camperProfileId], references: [id], onDelete: Cascade)
  camperProfileId String
  year            Year               @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId          String
  location        Location           @relation(fields: [locationId], references: [id])
  locationId      String
  parentConsent   String? // URL to uploaded parent consent form
  published       Boolean            @default(false)

  // Registration Engine fields (PRD Part 4)
  registrationNumber String?   @unique
  qrToken            String?   @unique
  submittedAt        DateTime?
  approvedAt         DateTime?
  rejectionReason    String?
  correctionRequest  String?
  reviewerId         String?
  checkedInAt        DateTime?
  checkedInById      String?
  checkedOutAt       DateTime?
  internalNotes      Json? // [{authorId, text, at}]
  waitlistPosition   Int?

  // Tribe Allocation (PRD Part 4A)
  tribe                 Tribe?    @relation(fields: [tribeId], references: [id])
  tribeId               String?
  tribeAssignedAt       DateTime?
  tribeAssignmentMethod String? // AUTOMATIC | MANUAL | HYBRID_OVERRIDE

  // Accommodation (Camp Structure module)
  room   Room?   @relation(fields: [roomId], references: [id])
  roomId String?
  bed    Bed?

  documents     Document[]
  auditLogs     AuditLog[]
  notifications Notification[]
  teacherAssignments TeacherCamperAssignment[]
  attendanceRecords  AttendanceRecord[]
  incidentReports    IncidentReport[]
  medicalVisits      MedicalVisit[]
  mealDistributions  MealDistribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([camperProfileId, yearId])
  @@index([locationId, status])
  @@index([yearId, status])
}

model DocumentRequirement {
  id              String     @id @default(cuid())
  year            Year       @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId          String
  name            String
  description     String?
  required        Boolean    @default(true)
  acceptedFormats String     @default("pdf,jpg,png,webp")
  maxSizeMb       Int        @default(10)
  scope           String     @default("CAMPER") // CAMPER | REGISTRATION
  sortOrder       Int        @default(0)
  documents       Document[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Document {
  id              String               @id @default(cuid())
  requirement     DocumentRequirement? @relation(fields: [requirementId], references: [id])
  requirementId   String?
  camperProfile   CamperProfile?       @relation(fields: [camperProfileId], references: [id], onDelete: Cascade)
  camperProfileId String?
  registration    Registration?        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId  String?
  url             String
  fileName        String
  fileType        String
  fileSize        Int
  status          String               @default("UPLOADED") // UPLOADED | APPROVED | REJECTED
  rejectionReason String?
  uploadedById    String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String?
  actorId        String?
  action         String
  previousValue  Json?
  newValue       Json?
  createdAt      DateTime      @default(now())

  @@index([registrationId])
  @@index([organizationId, createdAt])
}

model Notification {
  id             String        @id @default(cuid())
  organizationId String
  userId         String
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String?
  channel        String        @default("IN_APP") // IN_APP | EMAIL
  title          String
  body           String
  status         String        @default("QUEUED") // QUEUED | SENT | DELIVERED | FAILED
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([userId, readAt])
}

model Tribe {
  id            String         @id @default(cuid())
  year          Year           @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId        String
  name          String
  color         String?
  logoUrl       String?
  description   String?
  maxCapacity   Int?
  status        String         @default("ACTIVE") // ACTIVE | INACTIVE
  registrations Registration[]
  preferredByStaff StaffProfile[] @relation("PreferredTribe")
  assignedStaff    StaffProfile[] @relation("AssignedStaffTribe")
  points        Int            @default(0)
  pointsLog     TribePointsLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([yearId, name])
}

model SideEffect {
  id             String   @id @default(cuid())
  registrationId String
  type           String // ACCEPTANCE_WORKFLOW | RESUBMISSION_NOTICE | ...
  status         String   @default("QUEUED") // QUEUED | DONE | FAILED
  attempts       Int      @default(0)
  lastError      String?
  runAfter       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, runAfter])
}

model RegistrationCounter {
  id         String   @id @default(cuid())
  year       Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId     String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String
  value      Int      @default(0)

  @@unique([yearId, locationId])
}

// ─── Teacher & Volunteer (Staff) Modules ────────────────────────────────────

enum StaffType {
  TEACHER
  VOLUNTEER
}

enum StaffStatus {
  PENDING
  APPROVED
  REJECTED
  DEACTIVATED
}

model StaffSignupLink {
  id             String    @id @default(cuid())
  token          String    @unique
  type           StaffType
  year           Year      @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId         String
  organizationId String
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([yearId, type])
}

model StaffField {
  id             String           @id @default(cuid())
  organizationId String
  audience       StaffType
  name           String
  label          String
  type           ProfileFieldType
  options        String?
  required       Boolean          @default(false)
  sortOrder      Int              @default(0)
  fieldValues    StaffFieldValue[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, audience, name])
}

model StaffFieldValue {
  id             String       @id @default(cuid())
  value          String
  field          StaffField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId        String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  staffProfileId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([fieldId, staffProfileId])
}

model StaffProfile {
  id             String      @id @default(cuid())
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organizationId String
  year           Year        @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId         String
  type           StaffType
  status         StaffStatus @default(PENDING)

  // Personal
  firstName     String
  lastName      String
  preferredName String?
  gender        String?
  dateOfBirth   DateTime?
  phone         String
  email         String
  photoUrl      String?

  // Church
  church           String?
  churchDepartment String?
  yearsServing     String?
  workerStatus     String?

  // Camp preferences
  previousCampExperience String?
  areasOfStrength        String?
  preferredAgeGroup      String?
  preferredLocation      Location? @relation("PreferredStaffLocation", fields: [preferredLocationId], references: [id])
  preferredLocationId    String?
  preferredTribe         Tribe?    @relation("PreferredTribe", fields: [preferredTribeId], references: [id])
  preferredTribeId       String?

  // Volunteer-specific
  volunteerCategory String?
  teams             String[]

  // Shared
  skills                     String[]
  availability               String?
  emergencyContactName       String?
  emergencyContactPhone      String?
  emergencyContactRelationship String?
  medicalConditions          String?
  allergies                  String?

  // Review
  submittedAt    DateTime  @default(now())
  approvedAt     DateTime?
  rejectedAt     DateTime?
  rejectionReason String?
  reviewerId     String?
  deactivatedAt  DateTime?

  // Assignment (post-approval)
  assignedLocation   Location? @relation("AssignedStaffLocation", fields: [assignedLocationId], references: [id])
  assignedLocationId String?
  assignedTribe      Tribe?    @relation("AssignedStaffTribe", fields: [assignedTribeId], references: [id])
  assignedTribeId    String?

  // Camp Structure: department & position flags
  department        Department? @relation(fields: [departmentId], references: [id])
  departmentId      String?
  isDepartmentHead  Boolean     @default(false)
  isAssistantHead   Boolean     @default(false)
  isCampMonitor     Boolean     @default(false)
  isAssistantMonitor Boolean    @default(false)

  // Camp Structure: reporting hierarchy (exactly one of these two is set, enforced in the router)
  reportsTo        StaffProfile?  @relation("ReportsTo", fields: [reportsToId], references: [id])
  reportsToId      String?
  directReports    StaffProfile[] @relation("ReportsTo")
  reportsToUser    User?          @relation("StaffReportsToUser", fields: [reportsToUserId], references: [id])
  reportsToUserId  String?

  // Camp Structure: teacher accommodation assignment
  assignedHostel   Hostel? @relation("AssignedStaffHostel", fields: [assignedHostelId], references: [id])
  assignedHostelId String?
  assignedRoom     Room?   @relation("AssignedStaffRoom", fields: [assignedRoomId], references: [id])
  assignedRoomId   String?

  fieldValues      StaffFieldValue[]
  camperAssignments TeacherCamperAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yearId])
  @@index([organizationId, type, status])
}

model TeacherCamperAssignment {
  id             String       @id @default(cuid())
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  staffProfileId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  createdAt      DateTime     @default(now())

  @@unique([staffProfileId, registrationId])
}

model AttendanceSession {
  id          String             @id @default(cuid())
  year        Year               @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId      String
  locationId  String?
  tribeId     String?
  name        String
  date        DateTime
  createdById String
  records     AttendanceRecord[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model AttendanceRecord {
  id             String            @id @default(cuid())
  session        AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String
  registration   Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  status         String // PRESENT | ABSENT | LATE
  recordedById   String
  recordedAt     DateTime          @default(now())

  @@unique([sessionId, registrationId])
}

model IncidentReport {
  id             String        @id @default(cuid())
  organizationId String
  year           Year          @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId         String
  registration   Registration? @relation(fields: [registrationId], references: [id])
  registrationId String?
  reportedById   String
  severity       String // LOW | MEDIUM | HIGH
  title          String
  description    String
  status         String        @default("OPEN") // OPEN | RESOLVED
  createdAt      DateTime      @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
}

model MedicalVisit {
  id             String       @id @default(cuid())
  organizationId String
  year           Year         @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId         String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  recordedById   String
  complaint      String
  treatment      String?
  notes          String?
  visitedAt      DateTime     @default(now())
}

model MealDistribution {
  id             String       @id @default(cuid())
  year           Year         @relation(fields: [yearId], references: [id], onDelete: Cascade)
  yearId         String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  meal           String // BREAKFAST | LUNCH | DINNER
  date           DateTime     @db.Date
  servedById     String
  servedAt       DateTime     @default(now())

  @@unique([registrationId, meal, date])
}

// ─── Camp Structure & Organogram ────────────────────────────────────────────

model Department {
  id               String         @id @default(cuid())
  organizationId   String
  yearId           String? // per-year instance, matching Tribe; null = org-wide template
  name             String
  description      String?
  responsibilities String[]       @default([])
  status           String         @default("ACTIVE") // ACTIVE | INACTIVE
  staff            StaffProfile[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([organizationId, yearId, name])
}

model Hostel {
  id             String   @id @default(cuid())
  organizationId String
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId     String
  name           String // e.g. "Male Hostel A"
  gender         String? // MALE | FEMALE | MIXED
  rooms          Room[]
  staffAssigned  StaffProfile[] @relation("AssignedStaffHostel")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([locationId, name])
}

model Room {
  id            String         @id @default(cuid())
  hostel        Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hostelId      String
  name          String // e.g. "Room 12"
  capacity      Int?
  beds          Bed[]
  registrations Registration[]
  staffAssigned StaffProfile[] @relation("AssignedStaffRoom")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([hostelId, name])
}

model Bed {
  id             String        @id @default(cuid())
  room           Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId         String
  label          String // e.g. "Bed 1"
  status         BedStatus     @default(AVAILABLE)
  registration   Registration? @relation(fields: [registrationId], references: [id])
  registrationId String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([roomId, label])
}

model TribePointsLog {
  id        String   @id @default(cuid())
  tribe     Tribe    @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  tribeId   String
  delta     Int
  reason    String?
  actorId   String
  createdAt DateTime @default(now())
}
